<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What is this place called?"
            android:textColorHint="@color/white_text"
            app:boxStrokeColor="@color/amber"
            app:hintTextColor="@color/white_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white_text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_city"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Where is it?"
            android:textColorHint="@color/white_text"
            app:boxStrokeColor="@color/amber"
            app:hintTextColor="@color/white_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_city"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white_text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_note"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="What made this spot special?"
            android:textColorHint="@color/white_text"
            app:boxStrokeColor="@color/amber"
            app:hintTextColor="@color/white_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textColor="@color/white_text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Spot type"
            android:textColor="@color/muted_text"
            android:textSize="13sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layout_types"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeBeach"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="🏖️ Beach"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeCity"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="🏙️ City"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeNature"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="🌄 Nature"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeCafe"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="☕ Cafe"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeCulture"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="🏛️ Culture"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeForest"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌲 Forest"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Mood"
            android:textColor="@color/muted_text"
            android:textSize="13sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layout_moods"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoodPeaceful"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Peaceful"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoodExciting"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Exciting"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoodNostalgic"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Nostalgic"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoodDreamy"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Dreamy"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoodChaotic"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chaotic"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:strokeColor="@color/amber" />
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/amber"
            android:padding="16dp"
            android:text="@string/save_spot"
            android:textColor="@color/navy" />

    </LinearLayout>
</ScrollView>